# Demo profile — copy to .env.local (never commit secrets)

APP_NAME=Vault Core Demo
NEXT_PUBLIC_APP_URL=http://localhost:3013

# PostgreSQL (docker compose — host port 5437)
DATABASE_URL=postgresql://vault_demo:vault_demo_dev@localhost:5437/vault_core_demo

# Crypto profile (stable for local dev; change only before storing real data)
VAULT_AAD_CONTEXT_VAULT=vault-core-demo:vault:v1
VAULT_AAD_CONTEXT_ENVELOPE=vault-core-demo:envelope:v1
VAULT_PRF_SALT_PREFIX=vault-core-demo-passkey-prf-v1:

# Session
NEXT_PUBLIC_VAULT_AUTO_LOCK_MINUTES=15

# Vault password policy (for future setup page)
VAULT_PASSWORD_ENFORCEMENT=enforce
VAULT_PASSWORD_MIN_LENGTH=12

# Vault admin (package UI — enabled for local demo)
VAULT_ADMIN_ENABLED=true
VAULT_ADMIN_PATH=/admin/vault
