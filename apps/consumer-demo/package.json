{
  "name": "@vault-core/consumer-demo",
  "version": "0.0.0",
  "private": true,
  "description": "Local reference app for integrating @tgoliveira/vault-core (not published to npm)",
  "scripts": {
    "dev": "next dev -p 3013",
    "build": "next build",
    "start": "next start -p 3013",
    "typecheck": "tsc --noEmit",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:migrate": "node scripts/db-migrate.mjs"
  },
  "dependencies": {
    "@tgoliveira/vault-core": "file:../..",
    "next": "^16.2.9",
    "postgres": "^3.4.7",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.8",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "tailwindcss": "^4.1.8",
    "typescript": "^5.8.3"
  }
}
